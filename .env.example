# Configurações de SEO Programático e Performance

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.quitadoc.com.br

# IndexNow API Key (obter em https://www.indexnow.org)
INDEXNOW_API_KEY=sua-chave-indexnow-aqui

# Telefone para CTAs
NEXT_PUBLIC_PHONE=(21) 99607-6746

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Revalidation ISR (segundos)
NEXT_ISR_REVALIDATE=604800  # 7 dias

# Build settings
NODE_ENV=production
